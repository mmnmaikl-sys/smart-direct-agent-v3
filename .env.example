# Smart Direct Agent v3 — environment variables template
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- Core APIs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Yandex Direct + Metrika ---
YANDEX_DIRECT_TOKEN=
METRIKA_OAUTH_TOKEN=
METRIKA_COUNTER_ID=107734488

# --- Bitrix24 ---
BITRIX_WEBHOOK_URL=
BITRIX_WEBHOOK_TOKEN=<REDACTED_BITRIX_TOKEN>

# --- Competitor intel ---
KEYS_SO_API_KEY=
SPYWORDS_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Database ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Auth + HMAC (generate via: openssl rand -hex 32) ---
SDA_INTERNAL_API_KEY=
SDA_WEBHOOK_HMAC_SECRET=
HYPOTHESIS_HMAC_SECRET=

# --- PII salt (generate via: openssl rand -hex 32). Do NOT rotate after shadow start. ---
PII_SALT=

# --- Feature flags ---
SDA_TRUST_LEVEL_OVERRIDE=
SDA_PROTECTED_CAMPAIGN_IDS=708978456,708978457,708978458,709014142,709307228
